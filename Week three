#include <iostream>
#include <vector>
#include <limits>
#include <algorithm>

using namespace std;

class AttendanceSession {
private:
    string courseName;
    string date;
    vector<string> students;

public:
    AttendanceSession(string cName, string sessionDate)
        : courseName(cName), date(sessionDate) {}

    string getCourseName() const { return courseName; }
    string getDate() const { return date; }

    // Improved attendance logic (prevents duplicate names)
    void markAttendance(string studentName) {
        if (find(students.begin(), students.end(), studentName) != students.end()) {
            cout << "Student already marked present.\n";
        } else {
            students.push_back(studentName);
            cout << "Attendance marked successfully.\n";
        }
    }

    int getAttendanceCount() const {
        return students.size();
    }

    void displaySession() const {
        cout << "\nCourse: " << courseName << endl;
        cout << "Date: " << date << endl;
        cout << "Total Present: " << students.size() << endl;

        if (students.empty()) {
            cout << "No students recorded.\n";
        } else {
            for (size_t i = 0; i < students.size(); i++) {
                cout << i + 1 << ". " << students[i] << endl;
            }
        }
    }
};

// --------- Utility Input Validation ----------
int getValidatedInteger() {
    int value;
    while (!(cin >> value)) {
        cout << "Invalid input. Please enter a number: ";
        cin.clear();
        cin.ignore(numeric_limits<streamsize>::max(), '\n');
    }
    return value;
}

string getValidatedString(string prompt) {
    string input;
    cout << prompt;
    cin.ignore();
    getline(cin, input);

    while (input.empty()) {
        cout << "Input cannot be empty. Try again: ";
        getline(cin, input);
    }
    return input;
}

// --------- REPORT FUNCTION ----------
void generateSummaryReport(const vector<AttendanceSession>& sessions) {
    cout << "\n========== ATTENDANCE SUMMARY ==========\n";

    if (sessions.empty()) {
        cout << "No sessions available.\n";
        return;
    }

    int totalStudents = 0;

    for (size_t i = 0; i < sessions.size(); i++) {
        cout << "\nSession " << i + 1 << endl;
        cout << "Course: " << sessions[i].getCourseName() << endl;
        cout << "Date: " << sessions[i].getDate() << endl;
        cout << "Students Present: " << sessions[i].getAttendanceCount() << endl;

        totalStudents += sessions[i].getAttendanceCount();
    }

    cout << "\n----------------------------------------\n";
    cout << "Total Sessions: " << sessions.size() << endl;
    cout << "Total Attendance Records: " << totalStudents << endl;
}

// ------------------ MAIN ------------------
int main() {
    vector<AttendanceSession> sessions;
    int choice;

    do {
        cout << "\n========== Attendance Management System ==========\n";
        cout << "1. Create Lecture Session\n";
        cout << "2. Mark Attendance\n";
        cout << "3. View Sessions\n";
        cout << "4. Generate Summary Report\n";
        cout << "5. Exit\n";
        cout << "Enter choice: ";

        choice = getValidatedInteger();

        switch (choice) {

        case 1: {
            cin.ignore();
            string course, date;

            cout << "Enter Course Name: ";
            getline(cin, course);

            while (course.empty()) {
                cout << "Course name cannot be empty. Try again: ";
                getline(cin, course);
            }

            cout << "Enter Date (YYYY-MM-DD): ";
            getline(cin, date);

            while (date.empty()) {
                cout << "Date cannot be empty. Try again: ";
                getline(cin, date);
            }

            sessions.emplace_back(course, date);
            cout << "Lecture session created successfully!\n";
            break;
        }

        case 2: {
            if (sessions.empty()) {
                cout << "No sessions available.\n";
                break;
            }

            cout << "Select session index:\n";
            for (size_t i = 0; i < sessions.size(); i++) {
                cout << i << " - " << sessions[i].getCourseName()
                     << " (" << sessions[i].getDate() << ")\n";
            }

            int index = getValidatedInteger();

            if (index < 0 || index >= sessions.size()) {
                cout << "Invalid session index.\n";
                break;
            }

            cin.ignore();
            string studentName;
            cout << "Enter Student Name: ";
            getline(cin, studentName);

            while (studentName.empty()) {
                cout << "Name cannot be empty. Try again: ";
                getline(cin, studentName);
            }

            sessions[index].markAttendance(studentName);
            break;
        }

        case 3:
            if (sessions.empty()) {
                cout << "No sessions created.\n";
            } else {
                for (size_t i = 0; i < sessions.size(); i++) {
                    cout << "\n===== Session " << i + 1 << " =====";
                    sessions[i].displaySession();
                }
            }
            break;

        case 4:
            generateSummaryReport(sessions);
            break;

        case 5:
            cout << "Exiting program...\n";
            break;

        default:
            cout << "Invalid choice. Please try again.\n";
        }

    } while (choice != 5);

    return 0;
}
